# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Service Account ────────────────────────────────────────────────────
# Path to your service account JSON key file.
# The service account must have:
#   - Google Sheets API: Editor role on the target sheet
#   - Google Analytics Data API: Viewer role on the GA4 property
# Download from: Google Cloud Console → IAM & Admin → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Client 1 ─────────────────────────────────────────────────────────────────
# Google Sheets: the long ID from the sheet URL
# e.g. https://docs.google.com/spreadsheets/d/1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# The exact name of the tab (sheet) inside the spreadsheet
SHEET_TAB_NAME=Weekly Reports

# GA4 property ID (numeric only, no "properties/" prefix)
# Find in: Google Analytics → Admin → Property Settings
GA_PROPERTY_ID=123456789

# SamCart API key
# Find in: SamCart → Settings → API
SAMCART_API_KEY=your_samcart_api_key_here

# ─── Client 2 (optional — leave blank to inherit Client 1 values) ──────────────
CLIENT2_GOOGLE_SHEET_ID=
CLIENT2_SHEET_TAB_NAME=Weekly Reports
CLIENT2_GA_PROPERTY_ID=
CLIENT2_SAMCART_API_KEY=

# ─── App settings ─────────────────────────────────────────────────────────────
PORT=3000
